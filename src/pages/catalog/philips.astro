---
import BrandPage from '../../components/BrandPage.astro';
import LeadForm from '../../components/LeadForm.astro';
import Layout from '../../layouts/Layout.astro';
import { defaultLang, ui } from '../../i18n';

const lang = defaultLang;
const copy = ui[lang].brandPage.philips;
---

<Layout lang={lang} title={copy.seoTitle} description={copy.seoDescription}>
	<BrandPage brand="philips" lang={lang} />
	<LeadForm lang={lang} />
</Layout>

---
import Catalog from '../../components/Catalog.astro';
import LeadForm from '../../components/LeadForm.astro';
import Layout from '../../layouts/Layout.astro';
import { defaultLang, ui } from '../../i18n';

const lang = defaultLang;
const copy = ui[lang].catalogPage;
---

<Layout lang={lang} title={copy.seoTitle} description={copy.seoDescription}>
	<Catalog lang={lang} />
	<LeadForm lang={lang} />
</Layout>

---
import Catalog from '../components/Catalog.astro';
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
import { ui } from '../i18n';

const lang = 'ru';
const t = ui[lang];
---

<Layout
	lang={lang}
	title={t.homeTitle}
	description={t.homeDescription}
>
	<Welcome lang={lang} />
	<Catalog lang={lang} />
</Layout>

---
import logo from '../assets/ilock-logo-gradient.png';
import { site, whatsappLink } from '../config';
import { brandNames, brandOrder, getLocalePath, type Lang, ui } from '../i18n';

interface Props {
	lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = ui[lang];
const homePath = getLocalePath(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-main-color px-5 py-12 sm:px-8 lg:px-12">
	<div class="mx-auto flex max-w-7xl flex-col gap-8 md:flex-row md:items-center md:justify-between">
		<div>
			<a href={homePath} aria-label="iLOCK" class="inline-flex">
				<img src={logo.src} alt="iLOCK" class="h-12 w-auto" width="120" height="48" />
			</a>
			<p class="mt-4 max-w-sm text-sm leading-6 text-white/40">{t.footer.made}</p>
		</div>

		<div class="flex flex-wrap gap-x-12 gap-y-6">
			<nav class="flex flex-col gap-3 text-sm text-white/60">
				<a class="transition hover:text-accent-color" href={`${homePath}catalog/`}>{t.nav.catalog}</a>
				<a class="transition hover:text-accent-color" href={`${homePath}#about`}>{t.nav.about}</a>
				<a class="transition hover:text-accent-color" href={`${homePath}#contact`}>{t.nav.contact}</a>
				<a class="transition hover:text-accent-color" href={`tel:${site.phones[0].tel}`}>
					{site.phones[0].label}
				</a>
			</nav>

			<nav aria-label={t.footer.brands} class="flex flex-col gap-3 text-sm text-white/60">
				<span class="text-xs font-semibold uppercase tracking-[0.14em] text-white/30">
					{t.footer.brands}
				</span>
				{
					brandOrder.map((brand) => (
						<a class="transition hover:text-accent-color" href={`${homePath}catalog/${brand}/`}>
							{brandNames[brand]}
						</a>
					))
				}
			</nav>
		</div>

		<div class="flex items-center gap-3">
			<a
				href={whatsappLink(t.contact.whatsappHello)}
				target="_blank"
				rel="noopener noreferrer"
				aria-label={t.contact.whatsapp}
				class="flex h-11 w-11 items-center justify-center rounded-full border border-line transition hover:border-[#25D366]"
			>
				<svg viewBox="0 0 24 24" class="h-5 w-5 fill-white/70" aria-hidden="true">
					<path
						d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.87 9.87 0 0 0 4.79 1.22c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm5.43 12.38c-.3-.15-1.75-.86-2.02-.96-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.05-.17-.3-.02-.46.13-.6.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.6-.92-2.2-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.75-.72 2-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35z"
					></path>
				</svg>
			</a>
			<a
				href={site.instagramUrl}
				target="_blank"
				rel="noopener noreferrer"
				aria-label={t.contact.instagram}
				class="flex h-11 w-11 items-center justify-center rounded-full border border-line transition hover:border-accent-color"
			>
				<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
					<rect x="3" y="3" width="18" height="18" rx="5" class="text-white/70"></rect>
					<circle cx="12" cy="12" r="3.8" class="text-white/70"></circle>
					<circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" class="text-white/70"></circle>
				</svg>
			</a>
		</div>
	</div>

	<div class="mx-auto mt-10 max-w-7xl border-t border-line pt-6 text-xs text-white/30">
		© {year} iLOCK. {t.footer.rights}.
	</div>
</footer>

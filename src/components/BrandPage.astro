---
import { getCollection } from 'astro:content';
import LockCard from './LockCard.astro';
import { formatPrice } from '../config';
import {
	type Brand,
	brandNames,
	brandOrder,
	canonicalPath,
	getLocalePath,
	type Lang,
	localizeLock,
	sortLocks,
	ui,
} from '../i18n';

interface Props {
	brand: Brand;
	lang?: Lang;
}

const { brand, lang = 'ru' } = Astro.props;
const t = ui[lang];
const copy = t.brandPage[brand];
const homePath = getLocalePath(lang);

const locks = sortLocks(
	(await getCollection('locks')).map((lock) => localizeLock(lock, lang)),
).filter((lock) => lock.brand === brand);

const prices = locks.map((lock) => lock.price);
const cheapest = Math.min(...prices);
const dearest = Math.max(...prices);

const others = brandOrder.filter((b) => b !== brand);

const siteUrl = Astro.site ?? Astro.url;
const abs = (path: string) => new URL(canonicalPath(path), siteUrl).toString();
const canonical = abs(Astro.url.pathname);

const itemListLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: copy.h1,
	numberOfItems: locks.length,
	itemListElement: locks.map((lock, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		item: {
			'@type': 'Product',
			name: `${brandNames[brand]} ${lock.title}`,
			description: lock.description,
			brand: { '@type': 'Brand', name: brandNames[brand] },
			url: abs(`${homePath}catalog/${lock.slug}/`),
			offers: {
				'@type': 'Offer',
				price: lock.price,
				priceCurrency: 'KZT',
				availability: lock.comingSoon
					? 'https://schema.org/PreOrder'
					: 'https://schema.org/InStock',
			},
		},
	})),
};

const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: t.nav.catalog,
			item: abs(`${homePath}catalog/`),
		},
		{ '@type': 'ListItem', position: 2, name: brandNames[brand], item: canonical },
	],
};
---

<section class="bg-main-color px-5 pb-16 pt-28 sm:px-8 sm:pt-32 lg:px-12">
	<div class="mx-auto max-w-7xl">
		<nav aria-label="breadcrumb" class="flex items-center gap-2 text-sm text-white/40">
			<a href={`${homePath}catalog/`} class="transition hover:text-accent-color">{t.nav.catalog}</a>
			<span aria-hidden="true">/</span>
			<span class="text-white/70">{brandNames[brand]}</span>
		</nav>

		<div class="mt-8 max-w-3xl">
			<p
				class="flex items-center gap-3 text-xs font-medium uppercase tracking-[0.18em] text-accent-color sm:text-sm"
			>
				<span class="h-px w-8 shrink-0 bg-accent-color sm:w-12"></span>
				{t.brandPage.eyebrow}
			</p>

			<h1 class="mt-5 text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl">
				{copy.h1}
			</h1>

			<p class="mt-6 text-base leading-7 text-white/60 sm:text-lg sm:leading-8">{copy.lead}</p>

			<dl class="mt-8 flex flex-wrap gap-3">
				<div class="rounded-2xl border border-line bg-secondary-color px-5 py-3">
					<dt class="text-xs text-white/40">{t.brandPage.eyebrow}</dt>
					<dd class="mt-0.5 font-semibold text-white">{t.brandPage.models(locks.length)}</dd>
				</div>
				<div class="rounded-2xl border border-line bg-secondary-color px-5 py-3">
					<dt class="text-xs text-white/40">{t.brandPage.priceRange}</dt>
					<dd class="mt-0.5 font-semibold text-accent-color">
						{formatPrice(cheapest, cheapest === dearest ? undefined : dearest)}
					</dd>
				</div>
			</dl>
		</div>

		<div class="mt-12 grid gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
			{locks.map((lock, i) => <LockCard lock={lock} lang={lang} eager={i < 3} />)}
		</div>

		<nav class="mt-14 flex flex-wrap items-center gap-3 border-t border-line pt-8">
			<a
				href={`${homePath}catalog/`}
				class="rounded-full border border-line px-5 py-2.5 text-sm text-white/70 transition hover:border-accent-color/50 hover:text-white"
			>
				{t.brandPage.allBrands}
			</a>
			{
				others.map((other) => (
					<a
						href={`${homePath}catalog/${other}/`}
						class="rounded-full border border-line px-5 py-2.5 text-sm text-white/70 transition hover:border-accent-color/50 hover:text-white"
					>
						{t.brandPage[other].h1}
					</a>
				))
			}
		</nav>
	</div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(itemListLd)} is:inline />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline />

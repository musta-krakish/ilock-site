---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import LockCard from './LockCard.astro';
import { formatPrice, whatsappLink } from '../config';
import {
	brandNames,
	canonicalPath,
	getLocalePath,
	localizeLock,
	sortLocks,
	type Lang,
	ui,
} from '../i18n';

interface Props {
	lock: CollectionEntry<'locks'>;
	lang?: Lang;
}

const { lock: entry, lang = 'ru' } = Astro.props;
const t = ui[lang];
const lock = localizeLock(entry, lang);
const homePath = getLocalePath(lang);
const S = t.specs;

const all = sortLocks((await getCollection('locks')).map((l) => localizeLock(l, lang))).filter(
	(l) => l.slug !== lock.slug,
);
const related = [
	...all.filter((l) => l.brand === lock.brand),
	...all.filter((l) => l.brand !== lock.brand),
].slice(0, 3);

const monthly = Math.round(lock.price / 12 / 100) * 100;

// "Умный замок Philips DDL 7300" — the model number alone carries no search intent.
const productName = t.product.h1(brandNames[lock.brand], lock.title);

const accessValue = lock.access
	.map((a) => {
		const limit = lock.limits?.[a];
		return limit ? `${S.access[a]} (${t.product.upTo} ${limit})` : S.access[a];
	})
	.join(' · ');

const rows = [
	{ label: t.product.rows.material, value: S.material[lock.material] },
	{ label: t.product.rows.access, value: accessValue },
	{ label: t.product.rows.temp, value: `${lock.temp.min} °C … +${lock.temp.max} °C` },
	{ label: t.product.rows.power, value: S.power[lock.power] },
	{ label: t.product.rows.battery, value: t.product.months(lock.battery) },
	...(lock.app ? [{ label: t.product.rows.app, value: lock.app }] : []),
	{
		label: t.product.rows.brand,
		value: `${brandNames[lock.brand]} / ${t.product.years(lock.warranty)}`,
	},
	{ label: t.product.rows.iface, value: lock.interface.map((i) => S.iface[i]).join(', ') },
	{ label: t.product.rows.colors, value: lock.colors.map((c) => S.color[c]).join(', ') },
];

// Rich-result structured data for this product page.
const siteUrl = Astro.site ?? Astro.url;
const abs = (path: string) => new URL(canonicalPath(path), siteUrl).toString();
const canonical = abs(Astro.url.pathname);

const productLd = {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: productName,
	description: lock.seoDescription,
	image: new URL(lock.image.src, siteUrl).toString(),
	sku: lock.slug,
	category: t.catalog.title,
	brand: { '@type': 'Brand', name: brandNames[lock.brand] },
	offers: {
		'@type': 'Offer',
		url: canonical,
		price: lock.price,
		priceCurrency: 'KZT',
		availability: lock.comingSoon
			? 'https://schema.org/PreOrder'
			: 'https://schema.org/InStock',
		itemCondition: 'https://schema.org/NewCondition',
		seller: { '@type': 'Organization', name: 'iLOCK' },
	},
	additionalProperty: [
		{ '@type': 'PropertyValue', name: t.product.rows.material, value: S.material[lock.material] },
		{ '@type': 'PropertyValue', name: t.product.rows.access, value: accessValue },
		{ '@type': 'PropertyValue', name: t.product.rows.battery, value: t.product.months(lock.battery) },
	],
};

const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'iLOCK', item: abs(homePath) },
		{ '@type': 'ListItem', position: 2, name: t.nav.catalog, item: abs(`${homePath}catalog/`) },
		{
			'@type': 'ListItem',
			position: 3,
			name: brandNames[lock.brand],
			item: abs(`${homePath}catalog/${lock.brand}/`),
		},
		{ '@type': 'ListItem', position: 4, name: lock.title, item: canonical },
	],
};
---

<section class="bg-main-color px-5 pb-12 pt-24 sm:px-8 sm:pb-16 sm:pt-32 lg:px-12">
	<div class="mx-auto max-w-7xl">
		{/* Mirrors breadcrumbLd below — Google expects the markup to match what a visitor sees.
		    It is also the only in-page link from a model to its brand page. */}
		<nav aria-label="breadcrumb" class="flex flex-wrap items-center gap-2 text-sm text-ink/60">
			<a href={homePath} class="transition hover:text-accent-deep">iLOCK</a>
			<span aria-hidden="true">/</span>
			<a href={`${homePath}catalog/`} class="transition hover:text-accent-deep">
				{t.nav.catalog}
			</a>
			<span aria-hidden="true">/</span>
			<a href={`${homePath}catalog/${lock.brand}/`} class="transition hover:text-accent-deep">
				{brandNames[lock.brand]}
			</a>
			<span aria-hidden="true">/</span>
			<span class="text-ink/75">{lock.title}</span>
		</nav>

		<div class="mt-7 grid gap-8 sm:mt-8 lg:grid-cols-2 lg:gap-12">
			<div class="panel relative overflow-hidden rounded-3xl">
				<Image
					src={lock.image}
					alt={t.product.imgAlt(brandNames[lock.brand], lock.title)}
					widths={[480, 720, 900]}
					sizes="(min-width:1024px) 560px, 92vw"
					class="aspect-square w-full object-contain p-6 sm:p-12"
					loading="eager"
					fetchpriority="high"
				/>

				<div class="absolute left-4 top-4 flex flex-col items-start gap-2">
					{
						lock.featured && !lock.comingSoon && (
							<span class="btn-gold rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wide">
								{t.catalog.featured}
							</span>
						)
					}
					{
						lock.comingSoon && (
							<span class="rounded-full border border-accent-color/60 bg-secondary-color/90 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-accent-deep backdrop-blur-sm">
								{t.catalog.soon}
							</span>
						)
					}
					{
						lock.kazakhBrand && (
							<span class="rounded-full border border-line bg-secondary-color/90 px-3 py-1 text-[11px] font-medium text-ink/70 backdrop-blur-sm">
								{t.catalog.kazakhBrand}
							</span>
						)
					}
				</div>
			</div>

			<div>
				<p class="flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-accent-deep sm:text-xs">
					<span class="h-px w-8 bg-accent-color"></span>
					{brandNames[lock.brand]}
				</p>

				<h1 class="mt-4 text-[1.75rem] font-semibold tracking-tight sm:text-4xl lg:text-5xl">
					{productName}
				</h1>

				<p class="mt-4 text-[15px] leading-7 text-ink/65 sm:mt-5 sm:text-lg sm:leading-8">
					{lock.description}
				</p>

				<p class="mt-6 text-[1.75rem] font-semibold tracking-tight text-accent-deep sm:mt-7 sm:text-4xl">
					{
						lock.priceTo && (
							<span class="mr-1.5 font-sans text-base font-normal text-ink/60">{t.catalog.from}</span>
						)
					}
					{formatPrice(lock.price, lock.priceTo)}
				</p>

				<div class="mt-4 inline-flex items-center gap-2.5 rounded-xl bg-[#F14635] px-3.5 py-2">
					<span class="rounded-md bg-white px-1.5 py-0.5 text-[13px] font-extrabold leading-none text-[#F14635]">
						Kaspi
					</span>
					<span class="text-sm font-semibold text-white">
						{t.product.kaspiWord} · {t.product.kaspiTerm(formatPrice(monthly))}
					</span>
				</div>

				<div class="mt-7">
					<a
						href={whatsappLink(t.product.orderMsg(lock.title))}
						target="_blank"
						rel="noopener"
						class="btn-gold inline-flex h-13 w-full items-center justify-center rounded-full px-10 text-base font-semibold sm:h-14 sm:w-auto"
					>
						{t.product.order}
					</a>
				</div>

				<div class="mt-8 sm:mt-9">
					<h2 class="text-xs font-semibold uppercase tracking-[0.14em] text-ink/60 sm:text-sm">
						{t.product.access}
					</h2>
					<ul class="mt-4 flex flex-wrap gap-2">
						{
							lock.access.map((a) => (
								<li class="rounded-full border border-accent-color/40 bg-accent-color/8 px-3.5 py-1.5 text-sm text-ink/80">
									{S.access[a]}
									{lock.limits?.[a] && <span class="ml-1 text-ink/60">{lock.limits[a]}</span>}
								</li>
							))
						}
					</ul>
				</div>

				{
					lock.features.length > 0 && (
						<div class="mt-7">
							<h2 class="text-xs font-semibold uppercase tracking-[0.14em] text-ink/60 sm:text-sm">
								{t.product.features}
							</h2>
							<ul class="mt-4 grid gap-2 sm:grid-cols-2">
								{lock.features.map((f) => (
									<li class="flex items-start gap-2.5 text-sm leading-6 text-ink/75">
										<svg
											viewBox="0 0 24 24"
											class="mt-1 h-4 w-4 shrink-0 text-accent-color"
											fill="none"
											stroke="currentColor"
											stroke-width="2.4"
											aria-hidden="true"
										>
											<path d="m4 12.5 5 5L20 6.5" />
										</svg>
										{S.feature[f]}
									</li>
								))}
							</ul>
						</div>
					)
				}
			</div>
		</div>

		<div class="mt-12 grid gap-8 sm:mt-14 lg:mt-20 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.15fr)]">
			<div>
				<h2 class="text-xl font-bold sm:text-3xl">{t.product.about}</h2>
				<p class="mt-4 text-[15px] leading-7 text-ink/65 sm:mt-5 sm:text-base sm:leading-8">
					{lock.body}
				</p>
			</div>

			<div class="panel overflow-hidden rounded-2xl">
				<h2 class="border-b border-line bg-surface px-5 py-4 text-base font-semibold sm:px-6 sm:text-lg">
					{t.product.specs}
				</h2>
				<dl>
					{
						rows.map((row, i) => (
							<div
								class:list={[
									'grid gap-1 px-5 py-3.5 sm:grid-cols-[minmax(0,0.7fr)_minmax(0,1.3fr)] sm:gap-6 sm:px-6 sm:py-4',
									i % 2 === 0 ? 'bg-secondary-color' : 'bg-surface/60',
								]}
							>
								<dt class="text-[13px] text-ink/60 sm:text-sm">{row.label}</dt>
								<dd class="text-[13px] leading-6 text-ink/85 sm:text-sm">{row.value}</dd>
							</div>
						))
					}
				</dl>
			</div>
		</div>

		{
			related.length > 0 && (
				<div class="mt-14 sm:mt-24">
					<div class="flex items-end justify-between gap-4">
						<h2 class="text-xl font-bold sm:text-3xl">{t.product.related}</h2>
						<a
							href={`${homePath}catalog/`}
							class="shrink-0 text-sm font-medium text-accent-deep transition hover:text-accent-color"
						>
							{t.product.others} →
						</a>
					</div>
					<div class="mt-7 grid gap-3.5 sm:mt-8 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
						{related.map((item) => (
							<LockCard lock={item} lang={lang} />
						))}
					</div>
				</div>
			)
		}
	</div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(productLd)} is:inline />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline />

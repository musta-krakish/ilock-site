---
import { Image } from 'astro:assets';
import heroLock from '../assets/swag-lock.png';
import { site } from '../config';
import { getLocalePath, type Lang, ui } from '../i18n';

interface Props {
	lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = ui[lang];
const homePath = getLocalePath(lang);

const stats = [
	{ value: String(site.stats.choiceYear), label: t.hero.choice, highlight: true },
	{ value: String(site.stats.years), label: t.hero.years },
	{ value: String(site.stats.branches), label: t.hero.branches },
	{ value: String(site.stats.warranty), label: t.hero.warranty },
];
---

<section class="relative isolate overflow-hidden bg-main-color pt-20 text-white">
	<div class="mx-auto max-w-7xl px-5 pb-10 pt-8 sm:px-8 sm:pb-14 sm:pt-12 lg:px-12">
		<div class="grid items-start gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-8">
			<div class="lg:pt-6">
				<p
					class="flex items-center gap-3 text-[11px] font-medium uppercase tracking-[0.16em] text-accent-color sm:text-sm"
				>
					<span class="h-px w-8 shrink-0 bg-accent-color sm:w-12"></span>
					{t.hero.eyebrow}
				</p>

				<h1 class="mt-5 text-[2.5rem] font-semibold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
					{t.hero.title}
					<span class="mt-1 block text-white/85">{t.hero.tagline}</span>
				</h1>

				<p class="mt-5 max-w-xl text-base leading-7 text-white/60 sm:mt-6 sm:text-lg sm:leading-8">
					{t.hero.text}
				</p>

				<div class="mt-7 flex flex-col gap-3 sm:mt-8 sm:flex-row sm:gap-4">
					<a
						href={`${homePath}catalog/`}
						class="inline-flex h-13 items-center justify-center rounded-full bg-accent-color px-9 text-base font-semibold text-main-color transition hover:bg-accent-soft sm:h-14"
					>
						{t.hero.catalog}
					</a>
					<a
						href="#lead"
						class="inline-flex h-13 items-center justify-center rounded-full border border-accent-color/60 px-9 text-base font-semibold text-white transition hover:border-accent-color hover:bg-accent-color/10 sm:h-14"
					>
						{t.hero.contact}
					</a>
				</div>
			</div>

			<div
				class="relative mx-auto aspect-4/5 w-full max-w-120 overflow-hidden rounded-3xl border border-line"
			>
				<Image
					src={heroLock}
					alt="Умный замок iLock на двери"
					widths={[480, 720, 960, 1122]}
					sizes="(min-width:1024px) 480px, 92vw"
					class="h-full w-full object-cover"
					loading="eager"
					fetchpriority="high"
				/>
			</div>
		</div>

		<dl class="mt-12 grid grid-cols-2 gap-3 sm:mt-16 sm:gap-4 lg:grid-cols-4">
			{
				stats.map((stat) => (
					<div
						class:list={[
							'rounded-2xl border p-5 sm:p-6',
							stat.highlight
								? 'border-accent-color/45 bg-accent-color/10'
								: 'border-line bg-secondary-color/70',
						]}
					>
						<dt class="sr-only">{stat.label}</dt>
						<dd>
							<span
								class:list={[
									'text-3xl font-semibold tracking-tight sm:text-4xl',
									stat.highlight ? 'gold-text' : 'text-white',
								]}
							>
								{stat.value}
							</span>
							<span class="mt-2 block text-xs leading-5 text-white/55 sm:text-sm">{stat.label}</span>
						</dd>
					</div>
				))
			}
		</dl>
	</div>
</section>

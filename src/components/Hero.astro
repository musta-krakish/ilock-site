---
import { Image } from 'astro:assets';
import heroLock from '../assets/swag-lock.png';
import { site } from '../config';
import { getLocalePath, type Lang, ui } from '../i18n';

interface Props {
	lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = ui[lang];
const homePath = getLocalePath(lang);

const stats = [
	{ value: String(site.stats.choiceYear), label: t.hero.choice, highlight: true },
	{ value: String(site.stats.years), label: t.hero.years },
	{ value: String(site.stats.branches), label: t.hero.branches },
	{ value: String(site.stats.warranty), label: t.hero.warranty },
];
---

<section
	class="relative isolate overflow-hidden bg-main-color px-5 text-white sm:px-8 lg:px-12"
>
	<!-- Product visual bleeding off the right edge (desktop) -->
	<div class="pointer-events-none absolute inset-y-0 right-0 hidden w-[52%] lg:block">
		<Image
			src={heroLock}
			alt="Умный замок iLock на двери"
			widths={[720, 960, 1122]}
			sizes="52vw"
			class="h-full w-full object-cover object-left"
			loading="eager"
			fetchpriority="high"
		/>
		<div class="absolute inset-0 bg-linear-to-r from-main-color via-main-color/40 to-transparent"></div>
	</div>

	<div class="relative mx-auto max-w-7xl">
		<div
			class="grid items-center gap-12 pt-28 pb-16 sm:pt-32 lg:min-h-152 lg:grid-cols-2 lg:gap-8 lg:pt-40 lg:pb-28"
		>
			<!-- Copy -->
			<div>
				<p
					class="flex items-center gap-3 text-[11px] font-medium uppercase tracking-[0.16em] text-accent-color sm:text-sm"
				>
					<span class="h-px w-8 shrink-0 bg-accent-color sm:w-12"></span>
					{t.hero.eyebrow}
				</p>

				<h1
					class="mt-7 text-[2.75rem] font-semibold leading-[1.05] tracking-tight sm:text-6xl"
				>
					{t.hero.title}
					<span class="mt-1 block text-white/80">{t.hero.tagline}</span>
				</h1>

				<p class="mt-6 max-w-md text-base leading-8 text-white/55 sm:text-lg">
					{t.hero.text}
				</p>

				<div class="mt-9 flex flex-wrap items-center gap-4">
					<a
						href={`${homePath}catalog/`}
						class="group inline-flex h-12 items-center gap-2 rounded-full bg-accent-color px-8 text-[15px] font-semibold text-main-color transition hover:bg-accent-soft"
					>
						{t.hero.catalog}
						<svg
							class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.25"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M5 12h14M13 6l6 6-6 6"></path>
						</svg>
					</a>
					<a
						href="#lead"
						class="inline-flex h-12 items-center justify-center rounded-full px-6 text-[15px] font-semibold text-white/80 transition hover:text-accent-color"
					>
						{t.hero.contact}
					</a>
				</div>
			</div>

			<!-- Product visual for small screens -->
			<div
				class="relative order-first mx-auto aspect-4/5 w-full max-w-96 overflow-hidden rounded-3xl border border-line lg:hidden"
			>
				<Image
					src={heroLock}
					alt="Умный замок iLock на двери"
					widths={[480, 720, 960]}
					sizes="92vw"
					class="h-full w-full object-cover"
					loading="eager"
				/>
			</div>
		</div>

		<!-- Trust stats strip -->
		<dl class="grid grid-cols-2 gap-x-8 gap-y-8 border-t border-line py-10 sm:grid-cols-4 lg:py-12">
			{
				stats.map((stat) => (
					<div>
						<dt class="sr-only">{stat.label}</dt>
						<dd>
							<span
								class:list={[
									'text-3xl font-semibold tracking-tight sm:text-4xl',
									stat.highlight ? 'gold-text' : 'text-white',
								]}
							>
								{stat.value}
							</span>
							<span class="mt-2 block text-xs leading-5 text-white/45 sm:text-sm">{stat.label}</span>
						</dd>
					</div>
				))
			}
		</dl>
	</div>
</section>

---
import { Image } from 'astro:assets';
// Swapping the hero shot is a one-line change: point this import at the new file.
import heroLock from '../assets/swag-lock.png';
import { site } from '../config';
import { getLocalePath, type Lang, ui } from '../i18n';

interface Props {
	lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = ui[lang];
const homePath = getLocalePath(lang);

const stats = [
	{ value: String(site.stats.choiceYear), label: t.hero.choice, highlight: true },
	{ value: String(site.stats.years), label: t.hero.years },
	{ value: String(site.stats.branches), label: t.hero.branches },
	{ value: String(site.stats.warranty), label: t.hero.warranty },
];
---

<section class="relative isolate overflow-hidden bg-main-color px-5 pt-24 sm:px-8 sm:pt-28 lg:px-12 lg:pt-36">
	{/* Warm gold wash behind the headline — the only "heavy" colour left in the hero. */}
	<div
		class="pointer-events-none absolute -top-40 left-1/2 h-[28rem] w-[36rem] -translate-x-1/2 rounded-full bg-accent-color/20 blur-[130px] lg:left-1/4 lg:w-[44rem]"
		aria-hidden="true"
	>
	</div>

	<div class="relative mx-auto max-w-7xl">
		<div class="grid items-center gap-10 pb-12 lg:min-h-152 lg:grid-cols-2 lg:gap-14 lg:pb-20">
			<div class="order-1">
				<p
					class="flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-accent-deep sm:text-sm"
				>
					<span class="h-px w-8 shrink-0 bg-accent-color sm:w-12"></span>
					{t.hero.eyebrow}
				</p>

				<h1
					class="mt-5 text-[2.25rem] font-semibold leading-[1.08] tracking-tight sm:text-6xl lg:mt-7"
				>
					{t.hero.title}
					<span class="mt-1 block gold-text">{t.hero.tagline}</span>
				</h1>

				<p class="mt-5 max-w-md text-[15px] leading-7 text-ink/65 sm:mt-6 sm:text-lg sm:leading-8">
					{t.hero.text}
				</p>

				<div class="mt-7 flex flex-col gap-3 sm:mt-9 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
					<a
						href={`${homePath}catalog/`}
						class="btn-gold group inline-flex h-13 items-center justify-center gap-2 rounded-full px-8 text-[15px] font-semibold"
					>
						{t.hero.catalog}
						<svg
							class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.25"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M5 12h14M13 6l6 6-6 6"></path>
						</svg>
					</a>
					<a
						href="#lead"
						class="btn-ghost inline-flex h-13 items-center justify-center rounded-full px-7 text-[15px] font-semibold"
					>
						{t.hero.contact}
					</a>
				</div>
			</div>

			{/* The product shot stays dark — framed as a card it reads as a premium
			    accent instead of turning the whole page black. */}
			<div class="relative order-2 -mx-1 sm:mx-0">
				<div
					class="relative overflow-hidden rounded-[1.75rem] border border-line bg-night shadow-[0_40px_80px_-40px_rgba(60,44,16,0.55)] sm:rounded-[2rem]"
				>
					<Image
						src={heroLock}
						alt="Умный замок iLock на двери"
						widths={[480, 720, 960, 1122]}
						sizes="(min-width:1024px) 46vw, 92vw"
						class="aspect-4/3 w-full object-cover object-center sm:aspect-3/2 lg:aspect-4/5"
						loading="eager"
						fetchpriority="high"
					/>

					<div
						class="absolute left-4 top-4 inline-flex items-center gap-2 rounded-full border border-line bg-secondary-color/95 px-3.5 py-2 backdrop-blur-md sm:left-6 sm:top-6"
					>
						<span class="gold-text text-base font-semibold tracking-tight sm:text-lg">
							{site.stats.choiceYear}
						</span>
						<span class="text-[10px] font-semibold uppercase tracking-[0.14em] text-ink/60 sm:text-[11px]">
							{t.hero.choice}
						</span>
					</div>
				</div>
			</div>
		</div>

		<dl class="grid grid-cols-2 gap-x-6 gap-y-8 border-t border-line py-9 sm:grid-cols-4 sm:gap-x-8 lg:py-12">
			{
				stats.map((stat) => (
					<div>
						<dt class="sr-only">{stat.label}</dt>
						<dd>
							<span
								class:list={[
									'text-3xl font-semibold tracking-tight sm:text-4xl',
									stat.highlight ? 'gold-text' : 'text-ink',
								]}
							>
								{stat.value}
							</span>
							<span class="mt-2 block text-xs leading-5 text-ink/55 sm:text-sm">{stat.label}</span>
						</dd>
					</div>
				))
			}
		</dl>
	</div>
</section>

---
import { getCollection } from 'astro:content';
import LockCard from './LockCard.astro';
import SectionHeading from './SectionHeading.astro';
import { getLocalePath, localizeLock, sortLocks, type Lang, ui } from '../i18n';

interface Props {
	lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = ui[lang];
const homePath = getLocalePath(lang);

const all = sortLocks((await getCollection('locks')).map((lock) => localizeLock(lock, lang)));

const picks = all.filter((lock) => lock.featured).slice(0, 6);
---

<section id="popular" class="bg-surface px-5 py-12 sm:px-8 sm:py-16 lg:px-12 lg:py-20">
	<div class="mx-auto max-w-7xl">
		<div class="flex flex-wrap items-end justify-between gap-6">
			<SectionHeading
				eyebrow={t.featured.eyebrow}
				title={t.featured.title}
				accent={t.featured.titleAccent}
				text={t.featured.text}
				class="reveal"
			/>

			<a
				href={`${homePath}catalog/`}
				class="btn-ghost reveal hidden h-13 shrink-0 items-center rounded-full px-7 text-sm font-semibold lg:inline-flex"
			>
				{t.featured.all(all.length)}
			</a>
		</div>

		<div class="mt-9 grid gap-3.5 sm:mt-12 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
			{picks.map((lock, i) => <LockCard lock={lock} lang={lang} eager={i < 3} />)}
		</div>

		<a
			href={`${homePath}catalog/`}
			class="btn-gold mt-7 inline-flex h-13 w-full items-center justify-center rounded-full px-8 text-[15px] font-semibold lg:hidden"
		>
			{t.featured.all(all.length)}
		</a>
	</div>
</section>

---
import { getCollection } from 'astro:content';
import LockCard from './LockCard.astro';
import SectionHeading from './SectionHeading.astro';
import { getLocalePath, localizeLock, sortLocks, type Lang, ui } from '../i18n';

interface Props {
	lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = ui[lang];
const homePath = getLocalePath(lang);

const all = sortLocks((await getCollection('locks')).map((lock) => localizeLock(lock, lang)));

const picks = all.filter((lock) => lock.featured).slice(0, 6);
---

<section id="popular" class="bg-main-color px-5 py-10 sm:px-8 sm:py-14 lg:px-12">
	<div class="mx-auto max-w-7xl">
		<div class="flex flex-wrap items-end justify-between gap-6">
			<SectionHeading
				eyebrow={t.featured.eyebrow}
				title={t.featured.title}
				accent={t.featured.titleAccent}
				text={t.featured.text}
				class="reveal"
			/>

			<a
				href={`${homePath}catalog/`}
				class="reveal hidden h-13 shrink-0 items-center rounded-full border border-accent-color/60 px-7 py-3 text-sm font-semibold text-white transition hover:border-accent-color hover:bg-accent-color/10 lg:inline-flex"
			>
				{t.featured.all(all.length)}
			</a>
		</div>

		<div class="mt-12 grid gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
			{picks.map((lock, i) => <LockCard lock={lock} lang={lang} eager={i < 3} />)}
		</div>

		<a
			href={`${homePath}catalog/`}
			class="mt-8 inline-flex h-14 w-full items-center justify-center rounded-full bg-accent-color px-8 text-base font-semibold text-main-color transition hover:bg-accent-soft lg:hidden"
		>
			{t.featured.all(all.length)}
		</a>
	</div>
</section>

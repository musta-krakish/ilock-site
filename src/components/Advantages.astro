---
import { Image } from 'astro:assets';
import SectionHeading from './SectionHeading.astro';
import lockA from '../assets/images/locks/s940-max.png';
import lockB from '../assets/images/locks/g18.png';
import lockC from '../assets/images/locks/s90.png';
import { type Lang, ui } from '../i18n';

interface Props {
	lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = ui[lang];

const images = [null, lockA, lockB, null, null, lockC];
const items = t.about.items.map((item, i) => ({ ...item, img: images[i] }));
---

<section id="about" class="bg-main-color px-5 py-10 sm:px-8 sm:py-14 lg:px-12">
	<div class="mx-auto max-w-7xl">
		<SectionHeading
			eyebrow={t.about.eyebrow}
			title={t.about.title}
			accent={t.about.titleAccent}
			class="reveal"
		/>

		<div class="mt-12 grid auto-rows-fr gap-4 sm:mt-16 sm:grid-cols-2 lg:grid-cols-3">
			{
				items.map((item, i) => {
					if (item.img) {
						return (
							<article
								class:list={[
									'panel-hover group relative flex min-h-64 flex-col justify-between overflow-hidden rounded-3xl border p-7 text-ink sm:p-8',
									'bg-linear-to-b from-white to-zinc-100 shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)]',
									i === 1 ? 'border-accent-color/50' : 'border-black/5',
								]}
							>
								<Image
									src={item.img}
									alt=""
									aria-hidden="true"
									widths={[240, 360, 480]}
									sizes="340px"
									class="pointer-events-none absolute -right-4 bottom-2 top-2 h-[calc(100%-1rem)] w-auto select-none object-contain"
								/>
								<h3 class="relative max-w-[11ch] text-xl font-semibold leading-snug tracking-tight">
									{item.t}
								</h3>
								<p class="relative mt-3 max-w-[min(22ch,54%)] text-[15px] leading-6 text-black/55">
									{item.d}
								</p>
							</article>
						);
					}
					return (
						<article class="panel-hover group relative flex min-h-64 flex-col justify-between overflow-hidden rounded-3xl border border-white/10 bg-surface p-7 shadow-[0_28px_60px_-32px_rgba(0,0,0,0.75)] sm:p-8">
							<div class="pointer-events-none absolute inset-x-6 top-0 h-px bg-linear-to-r from-transparent via-white/20 to-transparent" />
							<div class="pointer-events-none absolute -bottom-16 -right-10 h-52 w-52 rounded-full bg-accent-color/12 opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-100" />
							<h3 class="relative max-w-[16ch] text-xl font-semibold leading-snug tracking-tight text-white">
								{item.t}
							</h3>
							<p class="relative mt-3 max-w-md text-[15px] leading-7 text-white/55">{item.d}</p>
						</article>
					);
				})
			}
		</div>
	</div>
</section>

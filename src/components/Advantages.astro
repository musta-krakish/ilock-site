---
import SectionHeading from './SectionHeading.astro';
import { type Lang, ui } from '../i18n';

interface Props {
	lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = ui[lang];

/** Icon per advantage, in the same order as `ui[lang].about.items`. */
const icons = ['kaspi', 'philips', 'shield', 'tools', 'truck', 'check'] as const;
const items = t.about.items.map((item, i) => ({ ...item, icon: icons[i] }));
---

<section id="about" class="bg-main-color px-5 py-20 sm:px-8 sm:py-28 lg:px-12">
	<div class="mx-auto max-w-7xl">
		<SectionHeading
			eyebrow={t.about.eyebrow}
			title={t.about.title}
			accent={t.about.titleAccent}
			class="reveal"
		/>

		<div class="mt-12 grid gap-4 sm:mt-16 sm:grid-cols-2 lg:grid-cols-3">
			{
				items.map((item, i) => (
					<div
						class:list={[
							'reveal rounded-2xl border p-6 sm:p-7 panel-hover',
							// One gold card anchors the grid, echoing the design reference.
							i === 1
								? 'border-accent-color/50 bg-gradient-to-br from-accent-color/20 to-accent-color/[0.04]'
								: 'border-line bg-secondary-color',
						]}
						style={`transition-delay:${i * 60}ms`}
					>
						<span
							class:list={[
								'inline-flex h-12 w-12 items-center justify-center rounded-xl',
								i === 1 ? 'bg-accent-color text-main-color' : 'bg-accent-color/10 text-accent-color',
							]}
						>
							{item.icon === 'kaspi' && (
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7">
									<rect x="2" y="5" width="20" height="14" rx="2.5" />
									<path d="M2 10h20" />
									<path d="M6 15h4" />
								</svg>
							)}
							{item.icon === 'philips' && (
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7">
									<path d="M12 3 4 6.2v5.3c0 4.6 3.4 8.4 8 9.5 4.6-1.1 8-4.9 8-9.5V6.2L12 3Z" />
									<path d="m8.6 12 2.3 2.3 4.5-4.6" />
								</svg>
							)}
							{item.icon === 'shield' && (
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7">
									<path d="M12 3 4 6.2v5.3c0 4.6 3.4 8.4 8 9.5 4.6-1.1 8-4.9 8-9.5V6.2L12 3Z" />
									<path d="M12 8v4l2.5 1.5" />
								</svg>
							)}
							{item.icon === 'tools' && (
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7">
									<path d="M14.7 6.3a4 4 0 0 0 5.2 5.2l-7.4 7.4a2.4 2.4 0 0 1-3.4-3.4l7.4-7.4a4 4 0 0 0-1.8-1.8Z" />
									<circle cx="6.5" cy="17.5" r="1" />
								</svg>
							)}
							{item.icon === 'truck' && (
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7">
									<path d="M2 7h11v9H2z" />
									<path d="M13 10h4.5l3.5 3.3V16h-8z" />
									<circle cx="6.5" cy="18" r="1.8" />
									<circle cx="17" cy="18" r="1.8" />
								</svg>
							)}
							{item.icon === 'check' && (
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7">
									<path d="m4 12.5 5 5L20 6.5" />
								</svg>
							)}
						</span>

						<h3 class="mt-5 text-lg font-semibold leading-snug text-white sm:text-xl">{item.t}</h3>
						<p class="mt-2.5 text-sm leading-6 text-white/55">{item.d}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

---
import { Image } from 'astro:assets';
import { formatPrice } from '../config';
import { brandNames, getLocalePath, type Lang, type LocalizedLock, ui } from '../i18n';

interface Props {
	lock: LocalizedLock;
	lang?: Lang;
	eager?: boolean;
}

const { lock, lang = 'ru', eager = false } = Astro.props;
const t = ui[lang];
const homePath = getLocalePath(lang);

const highlight = (['face', 'palm', 'fingerprint', 'pin', 'card', 'app', 'key'] as const)
	.filter((a) => lock.access.includes(a))
	.slice(0, 3);
---

<a
	href={`${homePath}catalog/${lock.slug}/`}
	data-brand={lock.brand}
	class="lock-card panel panel-hover group flex flex-col overflow-hidden rounded-2xl"
>
	<div class="relative aspect-square overflow-hidden bg-secondary-color">
		<Image
			src={lock.image}
			alt={t.product.imgAlt(brandNames[lock.brand], lock.title)}
			widths={[280, 420, 640]}
			sizes="(min-width:1280px) 320px, (min-width:768px) 40vw, 80vw"
			class="h-full w-full object-contain p-6 transition-transform duration-500 group-hover:scale-[1.06] sm:p-8"
			loading={eager ? 'eager' : 'lazy'}
		/>

		<div class="absolute left-3 top-3 flex flex-col items-start gap-2">
			{
				lock.featured && !lock.comingSoon && (
					<span class="btn-gold rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wide">
						{t.catalog.featured}
					</span>
				)
			}
			{
				lock.comingSoon && (
					<span class="rounded-full border border-accent-color/60 bg-secondary-color/90 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-accent-deep backdrop-blur-sm">
						{t.catalog.soon}
					</span>
				)
			}
			{
				lock.kazakhBrand && (
					<span class="rounded-full border border-line bg-secondary-color/90 px-3 py-1 text-[11px] font-medium text-ink/70 backdrop-blur-sm">
						{t.catalog.kazakhBrand}
					</span>
				)
			}
		</div>
	</div>

	<div class="flex flex-1 flex-col p-4 sm:p-6">
		<div class="flex items-center justify-between gap-3">
			<span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-accent-deep sm:text-xs">
				{brandNames[lock.brand]}
			</span>
			<span class="text-[11px] text-ink/60 sm:text-xs">{t.specs.material[lock.material]}</span>
		</div>

		<h3 class="mt-2.5 text-lg font-bold text-ink sm:mt-3 sm:text-2xl">{lock.title}</h3>

		<p class="mt-2.5 line-clamp-3 text-[13px] leading-6 text-ink/60 sm:mt-3 sm:text-sm">
			{lock.description}
		</p>

		<ul class="mt-4 flex flex-wrap gap-1.5">
			{
				highlight.map((a) => (
					<li class="rounded-full border border-line bg-surface px-2.5 py-1 text-[11px] text-ink/65">
						{t.specs.access[a]}
					</li>
				))
			}
		</ul>

		<div class="mt-auto flex items-end justify-between gap-3 border-t border-line pt-4 sm:pt-5">
			<p class="text-lg font-semibold tracking-tight text-accent-deep sm:text-2xl">
				{lock.priceTo && <span class="mr-1 font-sans text-sm font-normal text-ink/60">{t.catalog.from}</span>}
				{formatPrice(lock.price, lock.priceTo)}
			</p>
			<span class="shrink-0 text-xs font-medium text-ink/60 transition group-hover:text-accent-deep">
				{t.catalog.details} →
			</span>
		</div>
	</div>
</a>

---
interface Props {
	eyebrow: string;
	title: string;
	accent: string;
	text?: string;
	class?: string;
}

const { eyebrow, title, accent, text, class: className } = Astro.props;
---

<div class:list={['max-w-2xl', className]}>
	<p class="flex items-center gap-3 text-xs font-medium uppercase tracking-[0.18em] text-accent-color sm:text-sm">
		<span class="h-px w-8 shrink-0 bg-accent-color sm:w-12"></span>
		{eyebrow}
	</p>
	<h2 class="mt-5 text-3xl font-extrabold leading-tight tracking-tight sm:text-5xl">
		{title}{' '}
		<em class="font-display font-semibold italic gold-text">{accent}</em>
	</h2>
	{text && <p class="mt-5 text-base leading-7 text-white/55 sm:text-lg">{text}</p>}
</div>

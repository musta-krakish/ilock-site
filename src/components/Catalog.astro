---
import { getCollection } from 'astro:content';
import LockCard from './LockCard.astro';
import {
	brandNames,
	brandOrder,
	canonicalPath,
	getLocalePath,
	localizeLock,
	sortLocks,
	type Lang,
	ui,
} from '../i18n';

interface Props {
	lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = ui[lang];
const homePath = getLocalePath(lang);

const locks = sortLocks((await getCollection('locks')).map((lock) => localizeLock(lock, lang)));

const groups = brandOrder
	.map((brand) => ({ brand, count: locks.filter((l) => l.brand === brand).length }))
	.filter((g) => g.count > 0);

const siteUrl = Astro.site ?? Astro.url;
const abs = (path: string) => new URL(canonicalPath(path), siteUrl).toString();

// The full catalogue as one list, so the category page can qualify for a rich result
// instead of being read as an undifferentiated wall of links. Mirrors BrandPage.astro.
const itemListLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: t.catalogPage.h1,
	numberOfItems: locks.length,
	itemListElement: locks.map((lock, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		item: {
			'@type': 'Product',
			name: t.product.h1(brandNames[lock.brand], lock.title),
			description: lock.description,
			brand: { '@type': 'Brand', name: brandNames[lock.brand] },
			url: abs(`${homePath}catalog/${lock.slug}/`),
			offers: {
				'@type': 'Offer',
				price: lock.price,
				priceCurrency: 'KZT',
				availability: lock.comingSoon
					? 'https://schema.org/PreOrder'
					: 'https://schema.org/InStock',
			},
		},
	})),
};

const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'iLOCK', item: abs(homePath) },
		{
			'@type': 'ListItem',
			position: 2,
			name: t.nav.catalog,
			item: abs(`${homePath}catalog/`),
		},
	],
};
---

<section id="catalog" class="bg-main-color px-5 pb-12 pt-24 sm:px-8 sm:pb-16 sm:pt-32 lg:px-12">
	<div class="mx-auto max-w-7xl">
		<nav aria-label="breadcrumb" class="flex items-center gap-2 text-sm text-ink/60">
			<a href={homePath} class="transition hover:text-accent-deep">iLOCK</a>
			<span aria-hidden="true">/</span>
			<span class="text-ink/75">{t.catalog.eyebrow}</span>
		</nav>

		<div class="mt-7 max-w-3xl sm:mt-8">
			<p
				class="flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-accent-deep sm:text-sm"
			>
				<span class="h-px w-8 shrink-0 bg-accent-color sm:w-12"></span>
				{t.catalog.eyebrow}
			</p>
			<h1 class="mt-4 text-[2rem] font-semibold leading-tight tracking-tight sm:mt-5 sm:text-6xl">
				{t.catalogPage.h1}
			</h1>
			<p class="mt-5 text-[15px] leading-7 text-ink/65 sm:mt-6 sm:text-lg sm:leading-8">
				{t.catalogPage.lead}
			</p>
		</div>

		{/* Horizontally scrollable on phones so the brand filters never wrap into a wall of chips. */}
		<div
			class="-mx-5 mt-8 flex gap-2 overflow-x-auto px-5 pb-1 [scrollbar-width:none] sm:mx-0 sm:mt-10 sm:flex-wrap sm:overflow-visible sm:px-0 [&::-webkit-scrollbar]:hidden"
			role="tablist"
			aria-label={t.catalog.eyebrow}
		>
			<button
				type="button"
				role="tab"
				data-filter="all"
				aria-selected="true"
				class="filter-tab shrink-0 rounded-full border border-line bg-secondary-color px-5 py-2.5 text-sm font-medium text-ink/70 transition"
			>
				{t.catalog.all}
				<span class="ml-1.5 text-xs text-ink/60">{locks.length}</span>
			</button>
			{
				groups.map((group) => (
					<button
						type="button"
						role="tab"
						data-filter={group.brand}
						aria-selected="false"
						class="filter-tab shrink-0 rounded-full border border-line bg-secondary-color px-5 py-2.5 text-sm font-medium text-ink/70 transition"
					>
						{brandNames[group.brand]}
						<span class="ml-1.5 text-xs text-ink/60">{group.count}</span>
					</button>
				))
			}
		</div>

		<p class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-ink/60">
			<span>{t.footer.brands}:</span>
			{
				groups.map((group, i) => (
					<>
						{i > 0 && <span aria-hidden="true">·</span>}
						<a
							href={`${homePath}catalog/${group.brand}/`}
							class="text-ink/65 underline decoration-line underline-offset-4 transition hover:text-accent-deep hover:decoration-accent-color"
						>
							{t.brandPage[group.brand].h1}
						</a>
					</>
				))
			}
		</p>

		<div data-lock-grid class="mt-8 grid gap-3.5 sm:mt-10 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
			{locks.map((lock, i) => <LockCard lock={lock} lang={lang} eager={i < 3} />)}
		</div>

		<p data-empty hidden class="mt-12 text-center text-ink/55">{t.catalog.empty}</p>
	</div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(itemListLd)} is:inline />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline />

<script>
	const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
	const cards = document.querySelectorAll<HTMLElement>('[data-lock-grid] .lock-card');
	const empty = document.querySelector<HTMLElement>('[data-empty]');

	tabs.forEach((tab) =>
		tab.addEventListener('click', () => {
			const filter = tab.dataset.filter;

			tabs.forEach((other) => other.setAttribute('aria-selected', String(other === tab)));

			let shown = 0;
			cards.forEach((card) => {
				const match = filter === 'all' || card.dataset.brand === filter;
				card.hidden = !match;
				if (match) shown += 1;
			});

			if (empty) empty.hidden = shown > 0;
		}),
	);
</script>

<style>
	.filter-tab[aria-selected='true'] {
		background-image: linear-gradient(
			135deg,
			#f4cd62 0%,
			var(--color-accent-color) 48%,
			var(--color-accent-deep) 100%
		);
		border-color: transparent;
		color: var(--color-night);
		font-weight: 600;
	}

	.filter-tab[aria-selected='true'] span {
		color: color-mix(in srgb, var(--color-night) 60%, transparent);
	}

	.filter-tab:hover[aria-selected='false'] {
		border-color: color-mix(in srgb, var(--color-accent-color) 60%, transparent);
		color: var(--color-ink);
	}
</style>
